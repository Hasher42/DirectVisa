@{
    ViewData["Title"] = "Pre-Action Protocol & Judicial Review";
}

<!--<< Breadcrumb Section Start >>-->
<div class="breadcrumb-wrapper section-padding bg-cover" style="background-image: url('/assets/img/breadcrumb.jpg');">
    <div class="container">
        <div class="page-heading">
            <h1 class="wow fadeInUp" data-wow-delay=".3s">Pre-Action Protocol &amp; Judicial Review</h1>
            <ul class="breadcrumb-items wow fadeInUp" data-wow-delay=".5s">
                <li>
                    <a href='@Url.Action("Index", "Home")'>Home Page</a>
                </li>
                <li>
                    <i class="fal fa-minus"></i>
                </li>
                <li>
                    <a href='@Url.Action("ServiceDetails", "Home", new { key = "appeal-and-reviews" })'>Appeal &amp; Reviews</a>
                </li>
                <li>
                    <i class="fal fa-minus"></i>
                </li>
                <li>
                    PAP &amp; Judicial Review
                </li>
            </ul>
        </div>
    </div>
</div>

<!--<< Hero/Intro Section Start >>-->
<section class="about-section appeal-judicial-page appeal-guide-section fix section-padding">
    <div class="container">
        <div class="about-wrapper">
            <div class="row align-items-stretch g-4">
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay=".3s">
                    <div class="appeal-guide-image">
                        <img src="/assets/img/appeal/uk-justice-gavel.png"
                             alt="UK justice — gavel, scales and law book with Union Jack"
                             class="appeal-guide-img">
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="about-content">
                        <div class="section-title">
                            <span class="wow fadeInUp">Challenging a UK Visa Refusal</span>
                            <h2 class="title-anim">
                                Pre-Action Protocol Letters <br> &amp; Judicial Review
                            </h2>
                        </div>
                        <p class="mt-4 mt-md-0 wow fadeInUp" data-wow-delay=".3s">
                            A <strong>Pre-Action Protocol (PAP) letter</strong> &mdash; or &ldquo;letter before claim&rdquo; &mdash; is a mandatory, formal step to challenge a UK visa refusal before starting a <strong>Judicial Review (JR)</strong>. It notifies the Home Office of a potential legal challenge, giving them <strong>14 days</strong> to review their decision, which often leads to a quick resolution without litigation.
                        </p>
                        <ul class="about-list wow fadeInUp" data-wow-delay=".5s">
                            <li>
                                <i class="far fa-check me-2"></i>
                                Formal first step before any Judicial Review
                            </li>
                            <li>
                                <i class="far fa-check me-2"></i>
                                14-day Home Office response window
                            </li>
                            <li>
                                <i class="far fa-check me-2"></i>
                                Frequently resolves refusals without going to court
                            </li>
                        </ul>
                        <div class="about-button mt-4 wow fadeInUp" data-wow-delay=".7s">
                            <a href='@Url.Action("Contact", "Home")' class="theme-btn">
                                <span>
                                    Discuss your refusal with us
                                    <i class="fas fa-chevron-right"></i>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!--<< Pre-Action Protocol Section Start >>-->
<section class="about-section appeal-judicial-page appeal-guide-section fix section-padding pt-0">
    <div class="container">
        <div class="about-wrapper">
            <div class="row align-items-stretch g-4">
                <div class="col-lg-6 order-2 order-lg-1">
                    <div class="about-content appeal-guide-content">
                        <div class="section-title">
                            <span class="wow fadeInUp">Step 1</span>
                            <h2 class="title-anim">
                                Pre-Action Protocol (PAP) <br> for Visa Refusals
                            </h2>
                        </div>
                        <p class="wow fadeInUp" data-wow-delay=".3s">
                            The PAP is designed to encourage communication, allowing applicants to point out errors in a refusal decision and avoid unnecessary litigation.
                        </p>
                        <ul class="about-list wow fadeInUp" data-wow-delay=".5s">
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Purpose:</strong> Explain why the refusal is unlawful, unreasonable or procedurally improper.</span>
                            </li>
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Process:</strong> A letter is sent to the Home Office detailing the claim, the legal basis and the requested action.</span>
                            </li>
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Timeframe:</strong> The Home Office usually has 14 days to reply.</span>
                            </li>
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Templates:</strong> A standard template can be used to help draft a Pre-Action Protocol letter, as available on GOV.UK.</span>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-6 order-1 order-lg-2 wow fadeInRight" data-wow-delay=".3s">
                    <div class="appeal-guide-image">
                        <img src="/assets/img/appeal/visa-rejected-1.png"
                             alt="UK visa stamped REJECTED — Pre-Action Protocol letter context"
                             class="appeal-guide-img">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!--<< Judicial Review Section Start >>-->
<section class="about-section appeal-judicial-page appeal-guide-section fix section-padding pt-0">
    <div class="container">
        <div class="about-wrapper">
            <div class="row align-items-stretch g-4">
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay=".3s">
                    <div class="appeal-guide-image">
                        <img src="/assets/img/appeal/visa-rejected-2.png"
                             alt="UK visa stamped REJECTED — Judicial Review context"
                             class="appeal-guide-img">
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="about-content appeal-guide-content">
                        <div class="section-title">
                            <span class="wow fadeInUp">Step 2</span>
                            <h2 class="title-anim">
                                Judicial Review (JR) <br> for Visa Refusals
                            </h2>
                        </div>
                        <p class="wow fadeInUp" data-wow-delay=".3s">
                            If the PAP fails and the Home Office maintains its decision, you can apply to the <strong>Upper Tribunal (Immigration and Asylum Chamber)</strong> for a Judicial Review.
                        </p>
                        <ul class="about-list wow fadeInUp" data-wow-delay=".5s">
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Scope:</strong> JR challenges only the <em>lawfulness</em> of a decision &mdash; error of law, irrationality, or procedural unfairness &mdash; not a re-evaluation of the facts.</span>
                            </li>
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>When to use:</strong> Where other options (appeal or administrative review) are unavailable or have been exhausted.</span>
                            </li>
                            <li>
                                <i class="far fa-check"></i>
                                <span><strong>Alternatives:</strong> Sometimes a fresh visa application is faster and more cost-effective than a formal Judicial Review.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!--<< Call To Action Section Start >>-->
<section class="cta-chat-section section-padding pt-0">
    <div class="container">
        <div class="cta-chat-wrapper">
            <div class="chat-items wow fadeInUp" data-wow-delay=".3s">
                <div class="icon">
                    <i class="flaticon-chat"></i>
                </div>
                <div class="content">
                    <h3>Refused? Don&rsquo;t Give Up &mdash; Get a Lawful Second Opinion</h3>
                    <p>Our UK-based lawyers review your refusal letter and advise on PAP, JR, appeals or a fresh application.</p>
                </div>
            </div>
            <a href='@Url.Action("Contact", "Home")' class="theme-btn bg-white wow fadeInUp" data-wow-delay=".5s">
                <span>
                    Request a Consultation
                    <i class="fas fa-chevron-right"></i>
                </span>
            </a>
        </div>
    </div>
</section>
