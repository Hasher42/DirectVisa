            <section class="about-section fix section-padding pt-0">
                <div class="container">
                    <div class="about-wrapper">
                        <div class="row align-items-center g-4">
                            <div class="col-lg-6 wow fadeInLeft" data-wow-delay=".3s">
                                <div class="text-center text-lg-start">
                                    <img src="/assets/img/appeal/uk-justice-gavel.png"
                                         alt="UK justice — gavel, scales and law book with Union Jack"
                                         class="img-fluid"
                                         style="border-radius: 8px; max-width: 100%;">
                                </div>
                            </div>
                            <div class="col-lg-6 mt-4 mt-lg-0">
                                <div class="about-content">
                                    <div class="section-title">
                                        <span class="wow fadeInUp" style="color:#dc3545;">UK Visa Refused?</span>
                                        <h2 class="title-anim">
                                            Pre-Action Protocol &amp; <br> Judicial Review
                                        </h2>
                                    </div>
                                    <p class="mt-4 mt-md-0 wow fadeInUp" data-wow-delay=".3s">
                                        A <strong>Pre-Action Protocol (PAP) letter</strong> is the mandatory formal step to challenge an unlawful UK visa refusal &mdash; giving the Home Office <strong>14 days</strong> to review the decision. If they refuse to change it, the next step is a <strong>Judicial Review (JR)</strong> at the Upper Tribunal.
                                    </p>
                                    <ul class="about-list wow fadeInUp" data-wow-delay=".5s">
                                        <li>
                                            <i class="far fa-check me-2"></i>
                                            Identify errors of law, irrationality or procedural unfairness
                                        </li>
                                        <li>
                                            <i class="far fa-check me-2"></i>
                                            Often resolves the refusal without going to court
                                        </li>
                                        <li>
                                            <i class="far fa-check me-2"></i>
                                            We also advise when a fresh application is faster &amp; cheaper
                                        </li>
                                    </ul>
                                    <div class="about-button mt-4 wow fadeInUp" data-wow-delay=".7s">
                                        <a href='@Url.Action("AppealJudicialReview", "Home")' class="theme-btn">
                                            <span>
                                                Read the PAP &amp; JR guide
                                                <i class="fas fa-chevron-right"></i>
                                            </span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

