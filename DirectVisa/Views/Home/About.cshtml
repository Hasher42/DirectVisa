    <!--<< About Section Start >>--> 
    <section class="about-section fix section-padding">
        <div class="container">
            <div class="about-wrapper">
                <div class="row">
                    <div class="col-lg-6">
                        <div class="about-image-items">
                            <div class="border-shape">
                                <img src="/assets/img/about/border-shape.png" alt="shape-img">
                            </div>
                            <div class="about-image bg-cover wow fadeInLeft" data-wow-delay=".3s" style="background-image: url('/assets/img/about/about.jpg');">
                                <div class="about-image-2 wow fadeInUp" data-wow-delay=".5s">
                                    <img src="/assets/img/about/about-2.jpg" alt="about-img">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 mt-5 mt-lg-0">
                        <div class="about-content">
                            <div class="section-title">
                                <span class="wow fadeInUp">About Us</span>
                                <h2 class="title-anim">
                                    UK Visa Immigration & Passport Specialists
                                </h2>
                            </div>
                            <p class=" mt-4 mt-md-0 wow fadeInUp" data-wow-delay=".5s">
                                UK Visas Direct are specialists in UK visa applications and appeals with many years of experience. We provide honest advice, professional representation, and reasonable fees across visit, study, work, family, settlement, and citizenship routes.
                            </p>
                            <div class="circle-progress-bar-wrapper about-satisfaction-stat">
                                <div class="single-circle-bar wow fadeInUp" data-wow-delay=".3s">
                                    <div class="circle-bar" data-percent="100" data-duration="1000">
                                    </div>
                                    <div class="content">
                                        <h6>
                                            Client <br>Satisfaction
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <ul class="about-list wow fadeInUp" data-wow-delay=".7s">
                                <li>
                                    <i class="far fa-check me-2"></i>
                                    Clear eligibility assessment and lawful route planning
                                </li>
                                <li>
                                    <i class="far fa-check me-2"></i>
                                    UK immigration applications, appeals, and reviews
                                </li>
                                <li>
                                    <i class="far fa-check me-2"></i>
                                    Protection from fraud and illegal migration risks
                                </li>
                            </ul>
                            <div class="about-author">
                                <div class="about-button wow fadeInUp" data-wow-delay=".8s">
                                    <a href='@Url.Action("About", "Home")' class="theme-btn">
                                    <span>
