@model DirectVisa.Models.ServiceDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}
<!--<< Breadcrumb Section Start >>-->
        <div class="breadcrumb-wrapper section-padding bg-cover" style="background-image: url('/assets/img/breadcrumb.jpg');">
            <div class="container">
                <div class="page-heading">
                    <h1 class="wow fadeInUp" data-wow-delay=".3s">@Model.Title</h1>
                    <ul class="breadcrumb-items wow fadeInUp" data-wow-delay=".5s">
                        <li>
                            <a href='@Url.Action("Index", "Home")'>
                            Home Page
                            </a>
                        </li>
                        <li>
                            <i class="fal fa-minus"></i>
                        </li>
                        <li>
                            services
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!--<< Visa Details Section Start >>--> 
        <section class="visa-details-section fix section-padding">
            <div class="container">
                <div class="visa-details-wrapper">
                    <div class="row g-5">
                        <div class="col-lg-4 order-2 order-md-1">
                            <div class="visa-sidebar">
                                <div class="visa-widget-categories">
                                    <ul>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "visit-visas" })'>Visit Visas<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "student-graduate" })'>Student &amp; Graduate<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "family-settlement" })'>Family &amp; Settlement<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "skilled-worker-health-care" })'>Skilled Worker &amp; Health Care<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "business-investment" })'>Business &amp; Investment<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "temporary-youth-routes" })'>Temporary &amp; Youth Routes<span><i class="fas fa-chevron-right"></i></span></a></li>
                                        <li><a href='@Url.Action("ServiceDetails", "Home", new { key = "appeal-and-reviews" })'>Appeal and Reviews<span><i class="fas fa-chevron-right"></i></span></a></li>
                                    </ul>
                                </div>
                                <div class="visa-sidebar-widget">
                                    <div class="contact-bg text-center bg-cover" style="background-image: url('/assets/img/service/contact-bg.jpg');">
                                        <h4>Do You Have any <br> question?</h4>
                                        <h3><a href="tel:808555-0111">(808) 555-0111</a></h3>
                                        <p>It is a long established fact that a reader will be distracted by the rea</p>
                                        <a href='@Url.Action("Contact", "Home")' class="theme-btn bg-white">
                                            <span>
                                                contact us
                                                <i class="fas fa-chevron-right"></i>
                                            </span>
                                         </a>
                                    </div>
                                </div>
                                <a href='@Url.Action("Contact", "Home")' class="theme-btn w-100 text-center">
                                    <span><i class="fas fa-comment-dots me-3"></i> Request a consultation</span>
                                </a>
                            </div>
                        </div>
                        <div class="col-lg-8 order-1 order-md-2">
                            <div class="service-details-items">
                                <div class="details-image">
                                    <img src="@Model.ImageUrl" alt="@Model.Title">
                                </div>
                                <div class="details-content">
                                    <h2 class="title-anim">Service Overview</h2>
                                    <p class="mt-3">@Model.Overview</p>

                                    <h3 class="mt-5">What we cover</h3>
                                    <div class="row mt-3">
                                        <div class="col-lg-6">
                                            <div class="single-icon-items">
                                                @for (var i = 0; i < Model.Bullets.Length; i++)
                                                {
                                                    if (i % 2 == 0)
                                                    {
                                                        <div class="icon-box">
                                                            <div class="icon">
                                                                <i class="fas fa-check-circle"></i>
                                                            </div>
                                                            <h6>@Model.Bullets[i]</h6>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="single-icon-items">
                                                @for (var i = 0; i < Model.Bullets.Length; i++)
                                                {
                                                    if (i % 2 == 1)
                                                    {
                                                        <div class="icon-box">
                                                            <div class="icon">
                                                                <i class="fas fa-check-circle"></i>
                                                            </div>
                                                            <h6>@Model.Bullets[i]</h6>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        

